# ==============================================================
#  Deliphone — local environment template
#  Copy to `.env` and fill in real secrets for staging/prod.
# ==============================================================

# ----- Runtime -----
ENV=local
LOG_LEVEL=INFO
BACKEND_PORT=8000

# ----- PostgreSQL + PostGIS -----
POSTGRES_DB=deliphone
POSTGRES_USER=deliphone
POSTGRES_PASSWORD=deliphone
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# async driver (asyncpg) — used by the FastAPI app
DATABASE_URL=postgresql+asyncpg://deliphone:deliphone@postgres:5432/deliphone
# sync driver — used by Alembic
DATABASE_URL_SYNC=postgresql+psycopg://deliphone:deliphone@postgres:5432/deliphone

# ----- Redis -----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- S3 / MinIO -----
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=deliphone
S3_REGION=ru-central-1

# ----- Auth / JWT -----
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ----- CORS (comma-separated) -----
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ----- ЮKassa (fill before staging) -----
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# ----- SMS provider (SMS.ru or SMSC) -----
SMS_PROVIDER=smsru
SMS_PROVIDER_KEY=

# ----- Web Push (VAPID) -----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@deliphone.local

# ----- Frontend (read by Vite) -----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_CLIENT_PORT=5173
VITE_PARTNER_PORT=5174
VITE_ADMIN_PORT=5175
